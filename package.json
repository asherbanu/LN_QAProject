{
  "name": "com.assignment",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.27.1",
    "@wdio/cli": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "chai": "^6.2.2"
  },
  "scripts": {
    "test": "npm run test:parallel",
    "test:parallel": "wdio run ./wdio.conf.js --spec ./test/specs/ui/uie2e.spec.js --spec ./test/specs/api/apie2e.spec.js",
    "test:web": "wdio run ./wdio.conf.js --spec ./test/specs/ui/uie2e.spec.js",
    "test:api": "wdio run ./wdio.conf.js --spec ./test/specs/api/apie2e.spec.js",
    "report:generate": "allure generate results/allure-results --clean -o results/allure-report",
    "report:open": "allure open results/allure-report"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
